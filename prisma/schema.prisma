generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  SUPER_ADMIN
  HR_ADMIN
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(HR_ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
}

model Profile {
  id             String        @id @default(uuid())
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id])

  slug           String        @unique
  fullName       String
  title          String?
  company        String?
  department     String?

  phone          String?
  whatsapp       String?
  emailPublic    String?
  website        String?
  linkedin       String?
  address        String?
  mapUrl         String?
  photoUrl       String?       // user photo
  companyLogoUrl String?       // company logo

  isPublished    Boolean       @default(true)
  isActive       Boolean       @default(true)

  views          ProfileView[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ProfileView {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  referer   String?
  viewedAt  DateTime @default(now())

  @@index([profileId, viewedAt])
  @@index([viewedAt])
}
